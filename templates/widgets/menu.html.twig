<div class="offcanvas-nav">
	<input class="menu-icon" type="checkbox" id="menu-icon" name="menu-icon"/>
	<label for="menu-icon">
		<img class="menu-toggle" id="menuToggle" src="{{ url('theme://images/menu-offcanvas.svg') }}"/>
	</label>
	<nav class="nav"> 		
		<ul class="pt-5">
			{% for page in pages.children.visible %}
				{% if (page.home and not grav.user.authenticated) or (not page.home) %}
					{% set current_page = (page.active or page.activeChild) ? 'active' : '' %}
					{% set requires_access = page.header.login ? page.header.login.visibility_requires_access : false %}

					{% if (requires_access == true and page.header.access['site.login'] and grav.user.authorized == true) or requires_access == false %}
						<li class="menu-item {{ current_page|e }}">
							<a class="menu-item__link {{navbar_text_color}}" href="{{ page.url|e }}">
								{{ page.menu|e }}
							</a>
						</li>
					{% endif %}
				{% endif %}
			{% endfor %}


				{% if grav.user.authenticated %}
					<li class=" {{ current_page|e }}">
						<a class="logout-btn" href="{{ url('/task:login.logout') }}">{{ "METRICALO.LOGOUT"|t }}</a>
					</li>
				{% else %}
					<li class=" {{ current_page|e }}">
						<a class="login-btn" href="{{ url('/login') }}">{{ "METRICALO.LOGIN"|t }}</a>
					</li>
					<li class=" {{ current_page|e }}">
						<a class="signup-btn" href="{{ home_url|e }}{{ webdata('signup_url') }}">{{ "METRICALO.SIGNUP"|t }}</a>
					</li>
				{% endif %}
				


		

		</ul>
	</nav>
</div>
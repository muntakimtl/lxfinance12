{% set section_padding = 'px-4 sm:px-6 lg:px-8' %}
{% set site_js = 'user://themes/metricalo-base/dist/js/main.js?v=3' %}
{% set data = config.data %}
{% block render_block %}{% endblock %}

{% do assets.addJs('theme://assets/js/animation.js', {group: 'bottom', loading: 'defer'}) %}

<script>
function animateCounter(element, duration) {
    let target = parseInt(element.textContent, 10); // Extract number from text
    let start = 0;
    let stepTime = Math.abs(Math.floor(duration / target)); // Time per step

    let counter = setInterval(() => {
        start++;
        element.textContent = start; // Update the number

        if (start >= target) {
            clearInterval(counter); // Stop at target value
        }
    }, stepTime * 2);
}

document.addEventListener("DOMContentLoaded", function () {
    let numberElements = document.querySelectorAll(".count-up"); // Select all elements with class "count-up"
    
    numberElements.forEach((element) => {
        animateCounter(element, 2000); // Apply animation
    });
});


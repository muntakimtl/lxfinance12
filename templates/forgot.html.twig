{% set body_classes = "page-forgot"%}
{% extends 'partials/base.html.twig' %}

{% block article %}

  <div class="forgot-section">
    <div class="container ">
      {% embed "widgets/whq-card.html.twig" %}
        {% block card_title %}
          {{ "METRICALO.PAGE_FORGOT_PASSWORD"|t }}
        {% endblock %}

        {% block card_content %}
          {% include 'partials/notifications.html.twig' %}
          {% include 'partials/messages.html.twig' %}
          {% include 'partials/forgot-form.html.twig' with {form: forms('forgot-password'), action: url('recover-password')} %}
        {% endblock %}
      {% endembed %}
    </div>
  </div>


